# Database Configuration
DATABASE_URL=postgresql+asyncpg://postgres:YOUR_PASSWORD@db.YOUR_SUPABASE_URL.supabase.co:5432/postgres
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=flowmind

# AI Provider Settings
# Choose between 'openai' or 'gemini'
AI_PROVIDER=openai

# OpenAI Configuration
# Get your key from https://platform.openai.com/api-keys
OPENAI_API_KEY=your_openai_api_key_here

# Gemini Configuration (if using AI_PROVIDER=gemini)
# Get your key from https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# Application Settings
DEMO_USER_ID=demo-user
CORS_ORIGINS=http://localhost:3000

# Frontend Settings
NEXT_PUBLIC_API_URL=http://localhost:8000
